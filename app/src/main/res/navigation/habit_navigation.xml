<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/habit_navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.alfons.meonghabittracker.view.LoginFragment"
        android:label="Login Screen"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/actionDashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.alfons.meonghabittracker.view.DashboardFragment"
        android:label="Dashboard Screen"
        tools:layout="@layout/fragment_dashboard" >
        <action
            android:id="@+id/actionCreateHabitFragment"
            app:destination="@id/createHabitFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/createHabitFragment"
        android:name="com.alfons.meonghabittracker.view.CreateHabitFragment"
        android:label="Habit Screen"
        tools:layout="@layout/fragment_create_habit" >
        <action
            android:id="@+id/actionCreateHabitToDashboardFragment"
            app:destination="@id/dashboardFragment" />
        <argument
            android:name="habit"
            app:argType="com.alfons.meonghabittracker.model.Habit"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>
</navigation>